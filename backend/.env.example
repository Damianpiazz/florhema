# =========================
# APP
# =========================
NODE_ENV=
PORT=
AUTH_SALT_ROUNDS=
AUTH_SESSION_DURATION_HOURS=

# =========================
# FRONTEND
# =========================
CORS_ORIGINS=

# =========================
# DATABASE
# =========================
DATABASE_URL=""

# =========================
# OBSERVABILITY
# =========================

# OpenTelemetry collector host — set to the service name when using Docker.
OTEL_COLLECTOR_HOST=

# Service name for trace identification in the observability backend.
OTEL_SERVICE_NAME=

# OTLP transport protocol (http/protobuf, grpc).
OTEL_EXPORTER_OTLP_PROTOCOL=

# Set to false to disable telemetry (useful for tests or local-only work).
OTEL_ENABLED=

# Logging verbosity: debug | info | warn | error | silent
LOG_LEVEL=
