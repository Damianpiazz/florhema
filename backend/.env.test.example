# =========================
# APP
# =========================
NODE_ENV=test
PORT=0
AUTH_SALT_ROUNDS=4
AUTH_SESSION_DURATION_HOURS=1

# =========================
# FRONTEND
# =========================
CORS_ORIGINS=http://localhost:3000

# =========================
# DATABASE
# =========================
DATABASE_URL="postgresql://florhema_user:florhema_pass@localhost:5432/florhema_db_test?schema=public"

# =========================
# OBSERVABILITY
# =========================

# OpenTelemetry collector host — set to the service name when using Docker.
OTEL_COLLECTOR_HOST=

# Service name for trace identification in the observability backend.
OTEL_SERVICE_NAME=florhema-backend-test

# OTLP transport protocol (http/protobuf, grpc).
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# Set to false to disable telemetry (useful for tests or local-only work).
OTEL_ENABLED=false

# Logging verbosity: debug | info | warn | error | silent
LOG_LEVEL=silent
