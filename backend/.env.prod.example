# =========================
# APP
# =========================
NODE_ENV=production
PORT=4000
AUTH_SALT_ROUNDS=12
AUTH_SESSION_DURATION_HOURS=24

# =========================
# FRONTEND
# =========================
CORS_ORIGINS=https://tudominio.com

# =========================
# DATABASE
# =========================
DATABASE_URL="postgresql://florhema_user:florhema_pass@florhema-postgres:5432/florhema_db?schema=public"

# =========================
# OBSERVABILITY
# =========================

# OpenTelemetry collector host — set to the service name when using Docker.
OTEL_COLLECTOR_HOST=otel-collector

# Service name for trace identification in the observability backend.
OTEL_SERVICE_NAME=florhema-backend-prod

# OTLP transport protocol (http/protobuf, grpc).
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# Set to false to disable telemetry (useful for tests or local-only work).
OTEL_ENABLED=true

# Logging verbosity: debug | info | warn | error | silent
LOG_LEVEL=info
